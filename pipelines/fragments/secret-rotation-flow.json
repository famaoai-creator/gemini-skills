{
  "action": "pipeline",
  "name": "secret-rotation-flow-fragment",
  "description": "Checks for expiring credentials and triggers the rotation/re-authorization flow using the secret-actuator.",
  "context": {
    "service_id": "github"
  },
  "steps": [
    {
      "id": "check_expiry",
      "type": "capture",
      "op": "system:exec",
      "params": {
        "command": "node",
        "args": [
          "dist/scripts/cli.js",
          "run",
          "secret-actuator",
          "--",
          "--action", "check_expiry",
          "--service", "{{service_id}}"
        ],
        "allow_error": true,
        "export_as": "expiry_status"
      }
    },
    {
      "id": "conditional_rotation",
      "type": "apply",
      "op": "core:if",
      "params": {
        "condition": { "from": "expiry_status.needs_rotation", "operator": "equals", "value": true },
        "then": [
          {
            "op": "system:log",
            "params": { "message": "Secret rotation REQUIRED for {{service_id}}. Triggering OAuth Broker..." }
          },
          {
            "op": "system:exec",
            "params": {
              "command": "node",
              "args": [
                "dist/scripts/cli.js",
                "run",
                "secret-actuator",
                "--",
                "--action", "rotate",
                "--service", "{{service_id}}"
              ]
            }
          }
        ],
        "else": [
          {
            "op": "system:log",
            "params": { "message": "Secret for {{service_id}} is still valid. No rotation needed." }
          }
        ]
      }
    }
  ]
}
