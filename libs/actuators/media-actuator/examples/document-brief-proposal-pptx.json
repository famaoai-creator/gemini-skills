{
  "action": "pipeline",
  "context": {
    "context_path": "active/shared/tmp/media/document-brief-proposal-pptx.context.json"
  },
  "steps": [
    {
      "type": "capture",
      "op": "json_read",
      "params": {
        "path": "libs/actuators/media-actuator/examples/assets/document-brief-proposal-example.json",
        "export_as": "proposal_brief"
      }
    },
    {
      "type": "transform",
      "op": "document_outline_from_brief",
      "params": {
        "from": "proposal_brief",
        "export_as": "document_outline"
      }
    },
    {
      "type": "transform",
      "op": "brief_to_design_protocol",
      "params": {
        "from": "proposal_brief",
        "export_as": "compiled_design_protocol"
      }
    },
    {
      "type": "apply",
      "op": "generate_document",
      "params": {
        "brief": "{{proposal_brief}}",
        "output_path": "active/shared/tmp/media/document-brief-proposal-example.pptx"
      }
    }
  ]
}
