{
  "action": "pipeline",
  "context": {
    "context_path": "active/shared/tmp/orchestrator/request-to-status-report.context.json",
    "request_text": "システムの状態を教えて"
  },
  "steps": [
    {
      "type": "transform",
      "op": "request_to_status_brief",
      "params": {
        "export_as": "status_brief"
      }
    },
    {
      "type": "transform",
      "op": "collect_system_status_snapshot",
      "params": {
        "from": "status_brief",
        "export_as": "system_status_snapshot"
      }
    },
    {
      "type": "transform",
      "op": "status_snapshot_to_report",
      "params": {
        "from": "system_status_snapshot",
        "export_as": "system_status_report"
      }
    },
    {
      "type": "apply",
      "op": "write_file",
      "params": {
        "from": "system_status_report",
        "path": "active/shared/tmp/orchestrator/system-status-report.json"
      }
    }
  ]
}
