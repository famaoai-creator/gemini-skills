{
  "action": "pipeline",
  "context": {
    "context_path": "active/shared/tmp/orchestrator/delivery-pack-to-operator-packet.context.json",
    "delivery_pack": {
      "kind": "delivery-pack",
      "pack_id": "proposal-delivery-run-demo",
      "summary": "Proposal storyline deck and governed delivery pack are ready.",
      "main_artifact_id": "proposal-deck",
      "artifacts_by_role": {
        "primary": ["proposal-deck"],
        "evidence": ["delivery-pack-record"]
      },
      "artifacts": [
        {
          "id": "proposal-deck",
          "kind": "pptx",
          "path": "active/shared/tmp/media/proposal-delivery-run-demo.pptx",
          "description": "Generated proposal deck."
        },
        {
          "id": "delivery-pack-record",
          "kind": "delivery-pack",
          "path": "active/shared/runtime/delivery-packs/proposal-delivery-run-demo/proposal-delivery-run-demo.json",
          "description": "Governed delivery pack record."
        }
      ]
    }
  },
  "steps": [
    {
      "type": "transform",
      "op": "delivery_pack_to_operator_packet",
      "params": {
        "from": "delivery_pack",
        "export_as": "operator_packet"
      }
    },
    {
      "type": "transform",
      "op": "operator_packet_to_response_preview",
      "params": {
        "from": "operator_packet",
        "export_as": "response_preview"
      }
    },
    {
      "type": "apply",
      "op": "write_file",
      "params": {
        "from": "operator_packet",
        "path": "active/shared/tmp/orchestrator/delivery-operator-interaction-packet.json"
      }
    },
    {
      "type": "apply",
      "op": "write_file",
      "params": {
        "from": "response_preview",
        "path": "active/shared/tmp/orchestrator/delivery-response-preview.json"
      }
    }
  ]
}
