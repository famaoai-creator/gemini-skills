    {
      "type": "capture",
      "op": "export_session_handoff",
      "params": {
        "path": "active/shared/tmp/browser/web-runtime-session-handoff.json",
        "browser_session_id": "example-web-login-guarded",
        "prefer_persistent_context": true,
        "export_as": "runtime_session_handoff"
      }
    }
  ]
}
