{
  "action": "pipeline",
  "context": {
    "context_path": "active/shared/tmp/android/android-ui-node-input-dry-run.context.json"
  },
  "steps": [
    {
      "type": "capture",
      "op": "read_text_file",
      "params": {
        "path": "libs/actuators/android-actuator/examples/assets/mock-ui-tree.xml",
        "export_as": "last_ui_tree"
      }
    },
    {
      "type": "apply",
      "op": "input_text_into_ui_node",
      "params": {
        "from": "last_ui_tree",
        "selector_resource_id": "email",
        "selector_class_name": "EditText",
        "text": "operator@example.com",
        "dry_run": true,
        "export_as": "resolved_input_target"
      }
    }
  ]
}
