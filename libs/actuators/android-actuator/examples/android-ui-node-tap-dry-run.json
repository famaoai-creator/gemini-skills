{
  "action": "pipeline",
  "context": {
    "context_path": "active/shared/tmp/android/android-ui-node-tap-dry-run.context.json"
  },
  "steps": [
    {
      "type": "capture",
      "op": "read_text_file",
      "params": {
        "path": "libs/actuators/android-actuator/examples/assets/mock-ui-tree.xml",
        "export_as": "last_ui_tree"
      }
    },
    {
      "type": "transform",
      "op": "find_ui_nodes",
      "params": {
        "from": "last_ui_tree",
        "text": "passkey",
        "export_as": "passkey_matches"
      }
    },
    {
      "type": "apply",
      "op": "tap_ui_node",
      "params": {
        "from": "passkey_matches",
        "dry_run": true,
        "export_as": "resolved_tap_target"
      }
    }
  ]
}
