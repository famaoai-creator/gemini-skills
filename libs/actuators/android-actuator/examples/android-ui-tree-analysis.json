{
  "action": "pipeline",
  "context": {
    "context_path": "active/shared/tmp/android/android-ui-tree-analysis.context.json"
  },
  "steps": [
    {
      "type": "capture",
      "op": "read_text_file",
      "params": {
        "path": "libs/actuators/android-actuator/examples/assets/mock-ui-tree.xml",
        "export_as": "last_ui_tree"
      }
    },
    {
      "type": "transform",
      "op": "summarize_ui_tree",
      "params": {
        "from": "last_ui_tree",
        "export_as": "ui_tree_summary"
      }
    },
    {
      "type": "transform",
      "op": "find_ui_nodes",
      "params": {
        "from": "last_ui_tree",
        "text": "passkey",
        "export_as": "passkey_matches"
      }
    }
  ]
}
