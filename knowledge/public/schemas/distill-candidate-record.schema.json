{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/distill-candidate-record.schema.json",
  "title": "Distill Candidate Record",
  "type": "object",
  "required": ["candidate_id", "source_type", "title", "summary", "status", "target_kind", "created_at", "updated_at"],
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "enum": ["task_session", "mission", "artifact"] },
    "tier": { "type": "string", "enum": ["personal", "confidential", "public"] },
    "project_id": { "type": "string" },
    "mission_id": { "type": "string" },
    "task_session_id": { "type": "string" },
    "artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["proposed", "promoted", "archived"] },
    "target_kind": { "type": "string", "enum": ["pattern", "sop_candidate", "knowledge_hint", "report_template"] },
    "specialist_id": { "type": "string" },
    "locale": { "type": "string" },
    "work_loop": {
      "type": "object",
      "required": ["intent", "context", "resolution", "outcome_design", "teaming", "authority", "learning"],
      "properties": {
        "intent": {
          "type": "object",
          "required": ["label"],
          "properties": {
            "label": { "type": "string" }
          },
          "additionalProperties": false
        },
        "context": {
          "type": "object",
          "required": ["tier", "service_bindings"],
          "properties": {
            "project_id": { "type": "string" },
            "project_name": { "type": "string" },
            "tier": {
              "type": "string",
              "enum": ["personal", "confidential", "public"]
            },
            "locale": { "type": "string" },
            "service_bindings": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "resolution": {
          "type": "object",
          "required": ["execution_shape"],
          "properties": {
            "execution_shape": {
              "type": "string",
              "enum": ["direct_reply", "task_session", "mission", "project_bootstrap"]
            },
            "task_type": { "type": "string" }
          },
          "additionalProperties": false
        },
        "outcome_design": {
          "type": "object",
          "required": ["outcome_ids", "labels"],
          "properties": {
            "outcome_ids": {
              "type": "array",
              "items": { "type": "string" }
            },
            "labels": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "teaming": {
          "type": "object",
          "required": ["team_roles"],
          "properties": {
            "specialist_id": { "type": "string" },
            "specialist_label": { "type": "string" },
            "conversation_agent": { "type": "string" },
            "team_roles": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "authority": {
          "type": "object",
          "required": ["requires_approval"],
          "properties": {
            "requires_approval": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "learning": {
          "type": "object",
          "required": ["reusable_refs"],
          "properties": {
            "reusable_refs": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "promoted_ref": { "type": "string" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
