{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/artifact-record.schema.json",
  "title": "Artifact Record",
  "type": "object",
  "required": ["artifact_id", "kind", "storage_class"],
  "properties": {
    "artifact_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string" },
    "mission_id": { "type": "string" },
    "task_session_id": { "type": "string" },
    "kind": { "type": "string", "minLength": 1 },
    "storage_class": {
      "type": "string",
      "enum": ["repo", "artifact_store", "vault", "tmp", "external_ref"]
    },
    "path": { "type": "string" },
    "external_ref": { "type": "string" },
    "preview_text": { "type": "string" },
    "work_loop": {
      "type": "object",
      "required": ["intent", "context", "resolution", "outcome_design", "teaming", "authority", "learning"],
      "properties": {
        "intent": {
          "type": "object",
          "required": ["label"],
          "properties": {
            "label": { "type": "string" }
          },
          "additionalProperties": false
        },
        "context": {
          "type": "object",
          "required": ["tier", "service_bindings"],
          "properties": {
            "project_id": { "type": "string" },
            "project_name": { "type": "string" },
            "tier": {
              "type": "string",
              "enum": ["personal", "confidential", "public"]
            },
            "locale": { "type": "string" },
            "service_bindings": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "resolution": {
          "type": "object",
          "required": ["execution_shape"],
          "properties": {
            "execution_shape": {
              "type": "string",
              "enum": ["direct_reply", "task_session", "mission", "project_bootstrap"]
            },
            "task_type": { "type": "string" }
          },
          "additionalProperties": false
        },
        "outcome_design": {
          "type": "object",
          "required": ["outcome_ids", "labels"],
          "properties": {
            "outcome_ids": {
              "type": "array",
              "items": { "type": "string" }
            },
            "labels": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "teaming": {
          "type": "object",
          "required": ["team_roles"],
          "properties": {
            "specialist_id": { "type": "string" },
            "specialist_label": { "type": "string" },
            "conversation_agent": { "type": "string" },
            "team_roles": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "authority": {
          "type": "object",
          "required": ["requires_approval"],
          "properties": {
            "requires_approval": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "learning": {
          "type": "object",
          "required": ["reusable_refs"],
          "properties": {
            "reusable_refs": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "delivered_to": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["binding_id", "status"],
        "properties": {
          "binding_id": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["pending", "delivered", "failed"]
          },
          "external_url": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
