{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/generated-report-template-record.schema.json",
  "title": "Generated Report Template Record",
  "type": "object",
  "required": ["record_id", "kind", "tier", "title", "summary", "candidate_id", "created_at", "template_sections", "audience", "output_format"],
  "properties": {
    "record_id": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "const": "report_template" },
    "tier": { "type": "string", "enum": ["personal", "confidential", "public"] },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string" },
    "task_session_id": { "type": "string" },
    "specialist_id": { "type": "string" },
    "locale": { "type": "string" },
    "work_loop": {
      "type": "object",
      "required": ["intent", "context", "resolution", "outcome_design", "teaming", "authority", "learning"],
      "properties": {
        "intent": {
          "type": "object",
          "required": ["label"],
          "properties": { "label": { "type": "string" } },
          "additionalProperties": false
        },
        "context": {
          "type": "object",
          "required": ["tier", "service_bindings"],
          "properties": {
            "project_id": { "type": "string" },
            "project_name": { "type": "string" },
            "tier": { "type": "string", "enum": ["personal", "confidential", "public"] },
            "locale": { "type": "string" },
            "service_bindings": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "resolution": {
          "type": "object",
          "required": ["execution_shape"],
          "properties": {
            "execution_shape": { "type": "string", "enum": ["direct_reply", "task_session", "mission", "project_bootstrap"] },
            "task_type": { "type": "string" }
          },
          "additionalProperties": false
        },
        "outcome_design": {
          "type": "object",
          "required": ["outcome_ids", "labels"],
          "properties": {
            "outcome_ids": { "type": "array", "items": { "type": "string" } },
            "labels": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "teaming": {
          "type": "object",
          "required": ["team_roles"],
          "properties": {
            "specialist_id": { "type": "string" },
            "specialist_label": { "type": "string" },
            "conversation_agent": { "type": "string" },
            "team_roles": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "authority": {
          "type": "object",
          "required": ["requires_approval"],
          "properties": { "requires_approval": { "type": "boolean" } },
          "additionalProperties": false
        },
        "learning": {
          "type": "object",
          "required": ["reusable_refs"],
          "properties": {
            "reusable_refs": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "artifact_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "created_at": { "type": "string", "minLength": 1 },
    "template_sections": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "audience": { "type": "string", "minLength": 1 },
    "output_format": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
