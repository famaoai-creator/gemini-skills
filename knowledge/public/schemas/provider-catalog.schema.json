{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Provider Catalog",
  "type": "object",
  "required": ["version", "providers"],
  "properties": {
    "version": { "type": "string" },
    "providers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["transport", "defaultModel", "discovery", "suggestedModels"],
        "properties": {
          "transport": {
            "type": "string",
            "enum": ["acp", "print-json", "exec", "json-rpc", "openai-compatible"]
          },
          "defaultModel": { "type": "string", "minLength": 1 },
          "bootCommand": { "type": "string" },
          "bootArgs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "discovery": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind": { "type": "string", "enum": ["command", "env"] },
              "command": { "type": "string" },
              "versionArgs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "envVar": { "type": "string" }
            },
            "additionalProperties": false,
            "allOf": [
              {
                "if": {
                  "properties": { "kind": { "const": "command" } }
                },
                "then": {
                  "required": ["command"]
                }
              },
              {
                "if": {
                  "properties": { "kind": { "const": "env" } }
                },
                "then": {
                  "required": ["envVar"]
                }
              }
            ]
          },
          "suggestedModels": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
