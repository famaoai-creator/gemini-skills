{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "src",
    "module": "Node16",
    "target": "ES2022",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@agent/core": ["../../../dist/libs/core/index.d.ts"],
      "@agent/core/*": ["../../../dist/libs/core/*"]
    }
  },
  "include": ["src/**/*"]
}
