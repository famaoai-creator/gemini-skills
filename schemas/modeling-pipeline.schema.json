{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Modeling Pipeline ADF",
  "description": "Pipeline envelope for modeling-actuator semantic transforms.",
  "type": "object",
  "required": ["action", "steps"],
  "properties": {
    "action": { "const": "pipeline" },
    "context": { "type": "object" },
    "options": {
      "type": "object",
      "properties": {
        "max_steps": { "type": "integer" },
        "timeout_ms": { "type": "integer" }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "op", "params"],
        "properties": {
          "type": { "enum": ["capture", "transform", "apply", "control"] },
          "op": {
            "enum": [
              "read_json",
              "read_file",
              "glob_files",
              "shell",
              "ajv_validate",
              "json_query",
              "mermaid_gen",
              "web_profile_to_ui_flow_adf",
              "ui_flow_to_test_inventory",
              "test_inventory_to_browser_pipeline",
              "terraform_to_architecture_adf",
              "terraform_to_topology_ir",
              "write_file",
              "log",
              "if",
              "while"
            ]
          },
          "params": { "type": "object" }
        }
      }
    }
  }
}
