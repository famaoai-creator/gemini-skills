{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Integrity Check Configuration",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["integrity"]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["schema", "knowledge", "link", "metadata"]
          },
          "target": { "type": "string" },
          "options": { "type": "object" }
        },
        "required": ["type"]
      }
    }
  },
  "required": ["action", "checks"]
}
