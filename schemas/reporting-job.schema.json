{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Reporting Job Configuration",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["report"]
    },
    "reports": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["debt", "docs", "vital"]
          },
          "output_file": {
            "type": "string"
          },
          "options": {
            "type": "object"
          }
        },
        "required": ["type"]
      }
    }
  },
  "required": ["action", "reports"]
}
