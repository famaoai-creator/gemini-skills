{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.dev/schemas/design-spec.schema.json",
  "title": "Design Spec",
  "description": "Architectural design specification produced from a requirements draft. Captures components, interfaces, data flows, trade-offs, and open decisions so downstream implementation planning has a governed substrate to work from.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "project_name", "generated_at", "components"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "project_name": { "type": "string", "minLength": 1 },
    "source_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Paths of requirements drafts / briefs this spec derives from."
    },
    "architecture_summary": { "type": "string" },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "responsibility"],
        "properties": {
          "id": { "type": "string", "pattern": "^COMP-[0-9A-Z]+$" },
          "name": { "type": "string", "minLength": 1 },
          "responsibility": { "type": "string", "minLength": 1 },
          "interfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "kind"],
              "properties": {
                "name": { "type": "string" },
                "kind": {
                  "type": "string",
                  "enum": ["rest", "grpc", "event", "function_call", "cli", "ui", "file", "other"]
                },
                "description": { "type": "string" },
                "contract_ref": { "type": "string" }
              }
            }
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "description": "Other component ids or external systems." }
          },
          "technology_hints": {
            "type": "array",
            "items": { "type": "string" }
          },
          "requirements_refs": {
            "type": "array",
            "items": { "type": "string", "description": "FR / NFR ids this component fulfills." }
          }
        }
      }
    },
    "data_flows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "payload"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "payload": { "type": "string" },
          "protocol": { "type": "string" },
          "triggers": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "cross_cutting_concerns": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "security": { "type": "string" },
        "observability": { "type": "string" },
        "performance": { "type": "string" },
        "scaling": { "type": "string" },
        "deployment": { "type": "string" },
        "data_governance": { "type": "string" }
      }
    },
    "trade_offs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision", "chosen", "rationale"],
        "properties": {
          "decision": { "type": "string" },
          "options_considered": { "type": "array", "items": { "type": "string" } },
          "chosen": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "severity"],
        "properties": {
          "description": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "mitigation": { "type": "string" }
        }
      }
    },
    "open_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision"],
        "properties": {
          "decision": { "type": "string" },
          "options": { "type": "array", "items": { "type": "string" } },
          "current_lean": { "type": "string" },
          "blocking": { "type": "boolean", "default": false }
        }
      }
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "generated_by": { "type": "string" }
  }
}
