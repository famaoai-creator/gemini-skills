{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gemini Diagram ADF Protocol v1",
  "description": "The authoritative data format for AI-generated diagrams in the Gemini Ecosystem.",
  "type": "object",
  "required": ["protocol", "intent", "elements"],
  "properties": {
    "protocol": { "const": "gemini-diagram-v1" },
    "intent": {
      "enum": ["system_architecture", "project_roadmap", "api_sequence", "strategy_map", "logic_structure", "db_schema", "state_flow"]
    },
    "title": { "type": "string" },
    "theme": { "enum": ["base", "dark", "forest"], "default": "base" },
    "elements": {
      "type": "object",
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "type": "string" },
              "section": { "type": "string" },
              "start": { "type": "string" },
              "duration": { "type": "string" },
              "depends_on": { "type": "string" },
              "shape": { "enum": ["circle", "box"], "default": "box" }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        },
        "diagram": { "type": "string", "description": "Raw Mermaid fallback" }
      }
    },
    "overrides": {
      "type": "object",
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" },
        "theme_variables": { "type": "object" },
        "custom_style": { "type": "string" }
      }
    }
  }
}
