{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ingestion Pipeline Configuration",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["ingest"]
    },
    "pipelines": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["asset", "incident", "knowledge", "issue", "history", "knowledge-export"]
          },
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "options": {
            "type": "object",
            "properties": {
              "tenant": { "type": "string" },
              "tier": { "type": "string" },
              "asset_type": { "type": "string" },
              "force": { "type": "boolean" },
              "category": { "type": "string" }
            }
          }
        },
        "required": ["type"]
      }
    }
  },
  "required": ["action", "pipelines"]
}
